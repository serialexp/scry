# scry-webui environment — copy to ~/.config/scry-webui/webui.env and `chmod 600`.
# Read by the scry-webui.service systemd user unit (EnvironmentFile).
#
# Only SCRY_WEBUI_PASSWORD is required. LISTEN/QUERYD/SECURE_COOKIE have defaults
# in the unit (127.0.0.1:4180 → 127.0.0.1:4100, Secure cookie on); uncomment to
# override.

# REQUIRED — the single shared login password. The service will not start
# without it. Keep this file mode 600.
SCRY_WEBUI_PASSWORD=change-me

# OPTIONAL — bind address. The unit defaults to 127.0.0.1:4180 and expects a TLS
# reverse proxy (Caddy on scry.home.serial-experiments.com) in front of it. Use
# 0.0.0.0:4180 to reach it directly from other LAN hosts (but then turn the
# Secure cookie off — see below). See D-040.
#SCRY_WEBUI_LISTEN=0.0.0.0:4180

# OPTIONAL — upstream scry-queryd the byte-pipe dials.
#SCRY_WEBUI_QUERYD=127.0.0.1:4100

# OPTIONAL — emit a `Secure` session cookie. The unit sets this to 1 (correct
# behind the Caddy TLS proxy: the browser only ever speaks HTTPS). Set to 0 ONLY
# if you expose scry-webui directly over plain http:// — otherwise the browser
# drops the cookie and login silently fails.
#SCRY_WEBUI_SECURE_COOKIE=1
