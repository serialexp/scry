{
  "name": "scry-desktop",
  "version": "0.13.0",
  "description": "scry desktop query app — a TypeScript client for the scry-queryd binschema wire protocol, wrapped in a Tauri window.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "bun ../scripts/stamp-version.mjs && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "tauri": "tauri",
    "app:dev": "tauri dev",
    "app:build": "tauri build",
    "gen-proto": "bash ../scripts/gen-proto-ts.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.0",
    "apache-arrow": "^18.1.0",
    "solid-js": "^1.9.3",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^3.0.0"
  }
}
