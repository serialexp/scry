{
  "meta": {
    "title": "scry ingest wire protocol",
    "description": "Agent to server wire protocol for shipping metrics, logs, traces, and profiles to a scry ingest server. Long-lived TCP stream, length-framed messages, batch payloads compressed independently. Designed to be the only thing agents speak: the server's HTTP query surface is separate.",
    "version": "0.1.0"
  },

  "config": {
    "endianness": "big_endian",
    "bit_order": "msb_first"
  },

  "types": {
    "Frame": {
      "description": "Top-level discriminated union of all messages. Peek-discriminated on the message-type byte; each variant struct begins with a const-tagged uint8 that matches the discriminator.",
      "sequence": [
        {
          "name": "msg",
          "type": "discriminated_union",
          "discriminator": { "peek": "uint8" },
          "variants": [
            { "type": "Hello",       "when": "value === 0x01" },
            { "type": "HelloAck",    "when": "value === 0x02" },
            { "type": "Batch",       "when": "value === 0x10" },
            { "type": "BatchAck",    "when": "value === 0x11" },
            { "type": "FlowControl", "when": "value === 0x20" },
            { "type": "Ping",        "when": "value === 0x30" },
            { "type": "Pong",        "when": "value === 0x31" },
            { "type": "Goodbye",     "when": "value === 0x40" },
            { "type": "Error",       "when": "value === 0xF0" }
          ]
        }
      ]
    },

    "Hello": {
      "description": "First message from agent. Identifies agent, advertises capabilities, and lists the signals it intends to send. Sent exactly once at connection open.",
      "sequence": [
        { "name": "tag", "type": "uint8", "const": 1 },
        { "name": "protocol_version", "type": "uint16" },
        { "name": "agent_id", "type": "bytes", "kind": "fixed", "length": 16 },
        { "name": "agent_version", "type": "string", "kind": "length_prefixed", "length_type": "uint8", "encoding": "ascii" },
        { "name": "hostname", "type": "string", "kind": "length_prefixed", "length_type": "uint8", "encoding": "utf8" },
        { "name": "signals", "type": "uint8" },
        { "name": "capabilities", "type": "uint32" },
        { "name": "resource_attrs", "type": "array", "kind": "length_prefixed", "length_type": "uint16", "items": { "type": "LabelPair" } }
      ]
    },

    "HelloAck": {
      "description": "Server's response to Hello. Confirms protocol version, returns the server's writer_id and a session_id valid for the lifetime of this connection.",
      "sequence": [
        { "name": "tag", "type": "uint8", "const": 2 },
        { "name": "protocol_version", "type": "uint16" },
        { "name": "writer_id", "type": "string", "kind": "length_prefixed", "length_type": "uint8", "encoding": "ascii" },
        { "name": "session_id", "type": "uint64" },
        { "name": "capabilities", "type": "uint32" },
        { "name": "suggested_batch_bytes", "type": "uint32" },
        { "name": "max_batch_bytes", "type": "uint32" },
        { "name": "max_inflight_batches", "type": "uint16" }
      ]
    },

    "Batch": {
      "description": "A compressed, signal-specific batch of records. The payload, after decompression, is a SignalBatch variant.",
      "sequence": [
        { "name": "tag", "type": "uint8", "const": 16 },
        { "name": "session_id", "type": "uint64" },
        { "name": "batch_id", "type": "uint64" },
        { "name": "signal", "type": "uint8" },
        { "name": "ts_min_unix_nano", "type": "uint64" },
        { "name": "ts_max_unix_nano", "type": "uint64" },
        { "name": "record_count", "type": "uint32" },
        { "name": "compression", "type": "uint8" },
        { "name": "uncompressed_size", "type": "uint32" },
        { "name": "payload", "type": "bytes", "kind": "length_prefixed", "length_type": "uint32" }
      ]
    },

    "BatchAck": {
      "description": "Server's response per Batch. Either accepted (durable in WAL), throttled (slow down before retrying), or rejected (do not retry).",
      "sequence": [
        { "name": "tag", "type": "uint8", "const": 17 },
        { "name": "session_id", "type": "uint64" },
        { "name": "batch_id", "type": "uint64" },
        { "name": "status", "type": "uint8" },
        { "name": "retry_after_ms", "type": "uint32" },
        { "name": "reason_code", "type": "uint16" },
        { "name": "message", "type": "string", "kind": "length_prefixed", "length_type": "uint16", "encoding": "utf8" }
      ]
    },

    "FlowControl": {
      "description": "Asynchronous server-to-agent rate hint, per signal.",
      "sequence": [
        { "name": "tag", "type": "uint8", "const": 32 },
        { "name": "session_id", "type": "uint64" },
        { "name": "signal", "type": "uint8" },
        { "name": "max_bytes_per_sec", "type": "uint32" },
        { "name": "max_batches_inflight", "type": "uint16" },
        { "name": "valid_for_ms", "type": "uint32" }
      ]
    },

    "Ping": {
      "description": "Keepalive request. Either side may send.",
      "sequence": [
        { "name": "tag", "type": "uint8", "const": 48 },
        { "name": "nonce", "type": "uint64" }
      ]
    },

    "Pong": {
      "description": "Keepalive response. Echoes the Ping nonce.",
      "sequence": [
        { "name": "tag", "type": "uint8", "const": 49 },
        { "name": "nonce", "type": "uint64" }
      ]
    },

    "Goodbye": {
      "description": "Graceful close request. Either side may send.",
      "sequence": [
        { "name": "tag", "type": "uint8", "const": 64 },
        { "name": "reason_code", "type": "uint16" },
        { "name": "message", "type": "string", "kind": "length_prefixed", "length_type": "uint16", "encoding": "utf8" }
      ]
    },

    "Error": {
      "description": "Protocol-level error. Receiving an Error closes the connection.",
      "sequence": [
        { "name": "tag", "type": "uint8", "const": 240 },
        { "name": "code", "type": "uint16" },
        { "name": "message", "type": "string", "kind": "length_prefixed", "length_type": "uint16", "encoding": "utf8" }
      ]
    },

    "LabelPair": {
      "description": "A key-value label, used by every signal. UTF-8 throughout.",
      "sequence": [
        { "name": "key",   "type": "string", "kind": "length_prefixed", "length_type": "uint8",  "encoding": "utf8" },
        { "name": "value", "type": "string", "kind": "length_prefixed", "length_type": "uint16", "encoding": "utf8" }
      ]
    },

    "MetricsBatch": {
      "description": "Body of a metrics Batch after decompression. Series dictionary plus samples that reference fingerprints.",
      "sequence": [
        { "name": "series",  "type": "array", "kind": "length_prefixed", "length_type": "uint32", "items": { "type": "SeriesDictEntry" } },
        { "name": "samples", "type": "array", "kind": "length_prefixed", "length_type": "uint32", "items": { "type": "MetricSample" } }
      ]
    },

    "SeriesDictEntry": {
      "description": "Declares a series (set of labels) and its xxh3-64 fingerprint. The agent computes the fingerprint; the server validates it on receipt.",
      "sequence": [
        { "name": "fingerprint", "type": "uint64" },
        { "name": "metric_type", "type": "uint8" },
        { "name": "labels", "type": "array", "kind": "length_prefixed", "length_type": "uint16", "items": { "type": "LabelPair" } }
      ]
    },

    "MetricSample": {
      "description": "One scalar observation. Histograms and summaries are exploded into multiple samples before serialisation.",
      "sequence": [
        { "name": "fingerprint",  "type": "uint64" },
        { "name": "ts_unix_nano", "type": "uint64" },
        { "name": "value",        "type": "float64" }
      ]
    },

    "LogsBatch": {
      "description": "Body of a logs Batch after decompression. Records are pre-grouped by label set at the agent.",
      "sequence": [
        { "name": "streams", "type": "array", "kind": "length_prefixed", "length_type": "uint32", "items": { "type": "LogStream" } }
      ]
    },

    "LogStream": {
      "description": "A run of log entries sharing the same labels. Fingerprint follows the same xxh3-64 convention as metrics.",
      "sequence": [
        { "name": "fingerprint", "type": "uint64" },
        { "name": "labels",      "type": "array", "kind": "length_prefixed", "length_type": "uint16", "items": { "type": "LabelPair" } },
        { "name": "entries",     "type": "array", "kind": "length_prefixed", "length_type": "uint32", "items": { "type": "LogEntry" } }
      ]
    },

    "LogEntry": {
      "description": "One log line plus per-entry attributes that aren't part of the stream's stable label set.",
      "sequence": [
        { "name": "ts_unix_nano", "type": "uint64" },
        { "name": "severity",     "type": "uint8" },
        { "name": "body",         "type": "string", "kind": "length_prefixed", "length_type": "uint32", "encoding": "utf8" },
        { "name": "attributes",   "type": "array", "kind": "length_prefixed", "length_type": "uint16", "items": { "type": "LabelPair" } }
      ]
    },

    "TracesBatch": {
      "description": "Body of a traces Batch after decompression. OTel-aligned with per-batch resource/scope dictionaries.",
      "sequence": [
        { "name": "resources", "type": "array", "kind": "length_prefixed", "length_type": "uint16", "items": { "type": "ResourceEntry" } },
        { "name": "scopes",    "type": "array", "kind": "length_prefixed", "length_type": "uint16", "items": { "type": "ScopeEntry" } },
        { "name": "spans",     "type": "array", "kind": "length_prefixed", "length_type": "uint32", "items": { "type": "Span" } }
      ]
    },

    "ResourceEntry": {
      "sequence": [
        { "name": "labels", "type": "array", "kind": "length_prefixed", "length_type": "uint16", "items": { "type": "LabelPair" } }
      ]
    },

    "ScopeEntry": {
      "sequence": [
        { "name": "name",    "type": "string", "kind": "length_prefixed", "length_type": "uint8", "encoding": "utf8" },
        { "name": "version", "type": "string", "kind": "length_prefixed", "length_type": "uint8", "encoding": "ascii" }
      ]
    },

    "Span": {
      "description": "One span. References resource and scope dictionaries by index.",
      "sequence": [
        { "name": "resource_idx", "type": "uint16" },
        { "name": "scope_idx",    "type": "uint16" },
        { "name": "trace_id",     "type": "bytes", "kind": "fixed", "length": 16 },
        { "name": "span_id",      "type": "bytes", "kind": "fixed", "length": 8 },
        { "name": "parent_span_id", "type": "optional", "value_type": { "type": "bytes", "kind": "fixed", "length": 8 } },
        { "name": "name",            "type": "string", "kind": "length_prefixed", "length_type": "uint16", "encoding": "utf8" },
        { "name": "kind",            "type": "uint8" },
        { "name": "start_unix_nano", "type": "uint64" },
        { "name": "end_unix_nano",   "type": "uint64" },
        { "name": "status_code",     "type": "uint8" },
        { "name": "status_message",  "type": "string", "kind": "length_prefixed", "length_type": "uint16", "encoding": "utf8" },
        { "name": "attributes",      "type": "array",  "kind": "length_prefixed", "length_type": "uint16", "items": { "type": "LabelPair" } },
        { "name": "events",          "type": "array",  "kind": "length_prefixed", "length_type": "uint16", "items": { "type": "SpanEvent" } },
        { "name": "links",           "type": "array",  "kind": "length_prefixed", "length_type": "uint8",  "items": { "type": "SpanLink" } }
      ]
    },

    "SpanEvent": {
      "sequence": [
        { "name": "ts_unix_nano", "type": "uint64" },
        { "name": "name",         "type": "string", "kind": "length_prefixed", "length_type": "uint16", "encoding": "utf8" },
        { "name": "attributes",   "type": "array",  "kind": "length_prefixed", "length_type": "uint8",  "items": { "type": "LabelPair" } }
      ]
    },

    "SpanLink": {
      "sequence": [
        { "name": "trace_id",   "type": "bytes", "kind": "fixed", "length": 16 },
        { "name": "span_id",    "type": "bytes", "kind": "fixed", "length": 8 },
        { "name": "attributes", "type": "array", "kind": "length_prefixed", "length_type": "uint8", "items": { "type": "LabelPair" } }
      ]
    },

    "ProfilesBatch": {
      "description": "Body of a profiles Batch after decompression. v0.1 stores opaque pprof_gz blobs; the structured schema lands in v0.4.",
      "sequence": [
        { "name": "samples", "type": "array", "kind": "length_prefixed", "length_type": "uint32", "items": { "type": "ProfileBlob" } }
      ]
    },

    "ProfileBlob": {
      "sequence": [
        { "name": "ts_unix_nano",  "type": "uint64" },
        { "name": "duration_nano", "type": "uint64" },
        { "name": "labels",        "type": "array", "kind": "length_prefixed", "length_type": "uint16", "items": { "type": "LabelPair" } },
        { "name": "format",        "type": "uint8" },
        { "name": "data",          "type": "bytes", "kind": "length_prefixed", "length_type": "uint32" }
      ]
    }
  }
}
